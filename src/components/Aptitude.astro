---
const aptitude = [
    {
    svg: "/img/icons/icon1.svg", 
    h_4: "Clean Code",
    p_:"Writing maintainable, well-structured code that scales." },
    {
    svg: "/img/icons/icon2.svg", 
    h_4: "Design Sense",
    p_:"Bridging development and design for polished results." },
    {
    svg: "/img/icons/icon3.svg", 
    h_4: "Performance",
    p_:"Optimizing for speed without sacrificing user experience." },
    {
    svg: "/img/icons/icon4.svg", 
    h_4: "Collaboration",
    p_:"Working closely with teams to ship meaningful products." },
];
---

<div class="grid gap-4 sm:grid-cols-2">
    {
        aptitude.map((apt) => (
            <div class="group rounded-3xl border border-border bg-card p-6 transition-all hover:shadow-md hover:border-accent">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-2xl bg-secondary text-foreground">
                    <img src={apt.svg} width="18" height="18" />
                    
                </div>
                <h4 class="mb-2 text-sm font-semibold text-foreground">
                    {apt.h_4}
                </h4>
                <p class="text-sm leading-relaxed text-muted-foreground">
                    {apt.p_}
                </p>
            </div>
        ))
    }
</div>