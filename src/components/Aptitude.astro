---
const aptitude = [
    {
    icon: "/img/icons/icon1.svg", 
    title: "Clean Code",
    description:"Writing maintainable, well-structured code that scales." },
    {
    icon: "/img/icons/icon2.svg", 
    title: "Design Sense",
    description:"Bridging development and design for polished results." },
    {
    icon: "/img/icons/icon3.svg", 
    title: "Performance",
    description:"Optimizing for speed without sacrificing user experience." },
    {
    icon: "/img/icons/icon4.svg", 
    title: "Collaboration",
    description:"Working closely with teams to ship meaningful products." },
];
---

<div class="grid gap-4 sm:grid-cols-2">
    {
        aptitude.map((apt) => (
            <div class="group bg-white rounded-3xl border border-border bg-card p-6 transition-all hover:shadow-md hover:border-accent">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-2xl bg-secondary text-foreground">
                    <img src={apt.icon} width="18" height="18" />
                    
                </div>
                <h4 class="mb-2 text-sm font-semibold text-foreground">
                    {apt.title}
                </h4>
                <p class="text-sm leading-relaxed text-muted-foreground">   
                    {apt.description}
                </p>
            </div>
        ))
    }
</div>