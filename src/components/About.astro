---
import Technologies  from "./Technologies.astro"
import Aptitude from "./Aptitude.astro"
const photosRoute = "/img/"
const myProfilePhoto = "me.png"
---
<style>
    h2 {
        letter-spacing: -.025em;
        text-wrap: balance;
    }
    
</style>

<section id="about" class="px-6 py-24 md:py-32">
    <div class="mx-auto max-w-4xl">
        <span class="mb-4 inline-block rounded-full bg-secondary px-4 py-1.5 font-mono text-xs text-muted-foreground tracking-wide">
            About
        </span>
        <div class="flex flex-col gap-16">
            <!-- ABOUT INTRO -->
            <div class="max-w-2xl">
                <h2 class="mb-6 text-3xl font-bold text-primary">
                    A developer who cares <br> about the details
                </h2>
                <div class="flex flex-col gap-4 text-foreground">
                    <p>
                        I'm a full-stack developer with a passion for building web applications that are fast, accessible, and delightful to use. 
                        With experience across the entire stack, I enjoy turning complex problems into simple, elegant solutions.
                    </p>
                    <p>
                        When I'm not coding, you'll find me exploring new tools, contributing to open source, or sketching ideas 
                        for side projects that probably won't see the light of day.
                    </p>
                </div>
            </div>
            
            <!-- TECHNOLOGIES -->
            <div>    
                <h3 class="mb-4 text-sm font-bold text-primary">
                    Technologies I work with
                </h3>

                <div class="flex flex-wrap gap-2">
                    <!--TECH CARRUSEL -->
                    <Technologies title= "JavaScript" name="js.png"/>
                </div>
            </div>
            
            <!-- APTITUDES -->
            <Aptitude/>
            
        </div>
    </div>
</section>