---
import SocialMedia from "./SocialMedia.astro"
---

<sec id="contact" class="px-6 py-24 md:py-32" > 
    <div class="mx-auto max-w-4xl border border-border bg-white rounded-3xl bg-card p-8 md:p-12 text-center">
        <span class="mb-4 inline-block rounded-full bg-secondary px-4 py-1.5 font-mono text-xs text-foreground">
            Contact
        </span>
        <h2 class="mb-4 text-3xl font-bold tracking-tight text-primary sm:text-4xl text-balance">
            Let's work together 
        </h2>
        <p class="mx-auto mb-8 max-w-md text-base text-foreground">
            Have a project in mind or just want to say hello? I'd love to hear from you. Let's build something great.
        </p>
        <a class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-medium text-white shadow-sm transition-all hover:opacity-90" href="mailto:palmapintoluis08@gmail.com">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail" aria-hidden="true"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
            palmapintoluis08@gmail.com
        </a>

        <div class="my-8 flex items-center gap-4">
            <div class="h-px flex-1 bg-gray-200"></div>
            <span class="font-mono text-xs text-foreground">or find me on</span>
            <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        
        <SocialMedia />
    </div>
    
</div>
