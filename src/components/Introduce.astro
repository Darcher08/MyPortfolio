---
const photosRoute = "/img/"
const myProfilePhoto = "me.png"
---
<style>
    .text-gold {
        color: hsl(32.8, 71.9%, 56.7%);
    }
</style>

<section id="introduce" class="relative flex min-h-screen flex-col items-center justify-center px-6 pt-24 pb-12">
    <div class="flex flex-col items-center gap-8 text-center max-w-2xl">

        <div class="relative">
            <div class="h-28 w-28 overflow-hidden rounded-full border-4 border-card shadow-lg border-white ">
                <img alt="Portrait photo" width="112" height="112" decoding="async"
                data-nimg="1" class="h-full w-full object-cover" style="color:transparent"
                srcset={photosRoute+myProfilePhoto} src={photosRoute+myProfilePhoto}>
            </div>
            <span class="text-white absolute -bottom-1 -right-1 flex h-8 w-8 items-center justify-center rounded-full bg-black text-xs shadow-md">
                &lt;/&gt;
            </span>
        </div>

        <span class="rounded-full bg-secondary px-4 py-1.5 font-mono text-xs text-primary tracking-wide">Full-Stack Developer</span>
        <h1 class="text-4xl font-bold leading-tight tracking-tight text-primary sm:text-5xl md:text-6xl text-balance">
            Building digital<br>experiences that<br>
            <span class="text-gold">feel right</span>
        </h1>
        <p class="max-w-md text-base leading-relaxed text-foreground text-pretty">
            I craft clean, performant web applications with modern technologies. Focused on simplicity, usability, and thoughtful design.
        </p>
        <div class="flex items-center gap-3">
            <a href="#projects" class="rounded-full bg-black px-6 py-3 text-sm font-medium text-white shadow-sm transition-all hover:opacity-90">View Projects</a>
            <a href="#contact" class="rounded-full border border-gray bg-card px-6 py-3 text-sm font-medium text-foreground bg-white shadow-sm transition-all hover:bg-gray-200">Get in Touch</a>
        </div>
    </div>
</section>